127.0.0.1:{{CADDY_PORT}} {
    # Корневая директория сайта-заглушки
    root * {{STUB_DIR}}
    # Отдаём статические файлы
    file_server

    # Сжатие ответов
    encode gzip zstd

    header {
        # Убираем заголовок Caddy, чтобы не выдавать бэкенд
        -Server
        # Запрещаем браузеру угадывать MIME-тип — защита от XSS
        X-Content-Type-Options "nosniff"
        # Запрещаем встраивать страницу в iframe
        X-Frame-Options "SAMEORIGIN"
        # Убираем заголовок с версией бэкенда, если появится
        -X-Powered-By
    }

    log {
        output file {{LOG_DIR_CADDY}}/stub.log {
            # Ротация: новый файл после 10 МБ
            roll_size 10mb
            # Хранить не более 5 файлов истории
            roll_keep 5
        }
        format json
    }
}
